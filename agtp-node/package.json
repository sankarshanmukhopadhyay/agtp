{
  "name": "@agtp/agtp-node",
  "version": "0.1.0",
  "description": "Public AGTP handler API for Node.js / TypeScript.",
  "license": "MIT",
  "author": "Chris Hood <chris@nomotic.ai>",
  "homepage": "https://agtp.io",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
