{
    "name": "agtp/mod-php",
    "description": "PHP runtime module for AGTP. Connects to agtpd over the gateway socket and serves AGTP requests by dispatching to handlers registered in agtp-php.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://agtp.io",
    "authors": [
        {
            "name": "Chris Hood",
            "email": "chris@nomotic.ai"
        }
    ],
    "require": {
        "php": ">=8.1",
        "agtp/agtp-php": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Agtp\\ModPhp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Agtp\\ModPhp\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/run.php"
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../agtp-php"
        }
    ]
}
