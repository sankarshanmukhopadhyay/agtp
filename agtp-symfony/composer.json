{
    "name": "agtp/agtp-symfony",
    "description": "Symfony bundle that wires AGTP handlers into the Symfony service container. Services tagged `agtp.endpoint` are collected at boot; the agtp:serve console command runs the gateway worker against agtpd.",
    "type": "symfony-bundle",
    "license": "MIT",
    "homepage": "https://agtp.io",
    "authors": [
        {
            "name": "Chris Hood",
            "email": "chris@nomotic.ai"
        }
    ],
    "require": {
        "php": ">=8.1",
        "agtp/agtp-php": "^0.1",
        "agtp/mod-php": "^0.1",
        "symfony/console": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0",
        "symfony/config": "^6.4 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "Agtp\\Symfony\\": "src/"
        }
    },
    "extra": {
        "symfony": {
            "bundles": {
                "Agtp\\Symfony\\AgtpBundle": ["all"]
            }
        }
    }
}
