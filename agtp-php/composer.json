{
    "name": "agtp/agtp-php",
    "description": "Public AGTP handler API for PHP. The package PHP application developers import to write AGTP endpoints.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://agtp.io",
    "authors": [
        {
            "name": "Chris Hood",
            "email": "chris@nomotic.ai"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Agtp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Agtp\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always"
    }
}
