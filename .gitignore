# =============================================================================
# AGTP repository .gitignore
# =============================================================================
# What never goes in this repo:
#   1. Secrets (TLS keys, signing keys, API tokens, deploy keys)
#   2. Production data (registry contents, audit logs, real customer agents)
#   3. Build artifacts and caches
#   4. OS / editor junk
#
# When in doubt, add it here. Once a secret is committed and pushed to a
# public repo, treating it as compromised is the only safe response.
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets — never commit any of these, ever
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.der
id_rsa
id_ed25519
id_ecdsa
id_dsa
*.gpg
*.asc

# Environment files
.env
.env.*
!.env.example
secrets/
credentials/

# -----------------------------------------------------------------------------
# Production / runtime data
# -----------------------------------------------------------------------------
# The registry's data file MUST live outside the repo on the VPS
# (typically /var/lib/agtp/registry_data.json). Never commit this.
registry_data.json
server/transcripts/registry_data.json

# Server logs and audit trails
*.log
logs/
server/transcripts/
transcripts/

# Captured outputs from demo runs
server/transcripts/demo-output.txt
server/transcripts/server.log
server/transcripts/registry.log
server/transcripts/lauren.html
server/transcripts/lauren-card.png

# Custom agent definitions added at runtime should be reviewed before
# committing. The seed agents (Lauren) are tracked; runtime additions
# go in agents-runtime/ which is gitignored.
server/agents-runtime/

# -----------------------------------------------------------------------------
# elemen (AGTP browser) — runtime data
# -----------------------------------------------------------------------------
# elemen normally writes history.json into the per-user OS data directory
# (APPDATA / Library / XDG_CONFIG_HOME). If a contributor sets
# ELEMEN_DATA_DIR to a path inside the repo for testing, keep the local
# history out of git.
elemen/history.json
elemen/data/

# Pywebview / PyInstaller / freezing artifacts (in case anyone packages
# elemen as a standalone app).
elemen/build/
elemen/dist/
*.spec

# -----------------------------------------------------------------------------
# IETF draft build artifacts
# -----------------------------------------------------------------------------
.refcache/
ietf/.refcache/
*.txt.bak
*.xml.bak

# kramdown-rfc / xml2rfc output (generated from .md sources)
ietf/draft-*-[0-9][0-9].txt
ietf/draft-*-[0-9][0-9].xml
ietf/draft-*-[0-9][0-9].html

# Allow the markdown sources through
!ietf/draft-*-[0-9][0-9].md

# -----------------------------------------------------------------------------
# Python build / cache
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv/
.env-py/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Type checkers
.mypy_cache/
.pyre/
.pytype/

# -----------------------------------------------------------------------------
# Editor / IDE / agent tooling
# -----------------------------------------------------------------------------
.vscode/
.idea/
# Claude Code session/worktree/plan state — never commit
.claude/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# OS junk
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Local notes / scratchpads (don't accidentally publish drafts)
# -----------------------------------------------------------------------------
NOTES.md
TODO.md
SCRATCH.md
*.scratch
*.local
