{
  "name": "@agtp/mod-node",
  "version": "0.1.0",
  "description": "Node.js runtime module for AGTP. Connects to agtpd over the gateway socket and serves AGTP requests via agtp-node handlers.",
  "license": "MIT",
  "author": "Chris Hood <chris@nomotic.ai>",
  "homepage": "https://agtp.io",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mod-node": "./bin/run.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@agtp/agtp-node": "file:../agtp-node"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
